<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.8.1/github-markdown-light.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github.min.css">
  <style>
    :root {
      --page-bg: #f3f6fb;
      --card-bg: #ffffff;
      --border: #d0d7de;
      --text: #24292f;
      --muted: #57606a;
      --link: #0969da;
      --code-bg: #f6f8fa;
      --shadow: 0 8px 30px rgba(31, 35, 40, 0.08);
    }

    body {
      margin: 0;
      color: var(--text);
      background:
        radial-gradient(circle at 15% 15%, #e8f1ff 0%, transparent 35%),
        radial-gradient(circle at 85% 10%, #eef9f2 0%, transparent 30%),
        var(--page-bg);
    }

    .container {
      max-width: 1024px;
      margin: 0 auto;
      padding: 2rem 1rem 3rem;
    }

    .topnav {
      margin-bottom: 1rem;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .topnav a {
      color: var(--link);
      text-decoration: none;
      font-weight: 600;
    }

    .topnav a:hover { text-decoration: underline; }

    .markdown-body {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 2rem;
      line-height: 1.8;
      font-size: 16px;
    }

    .markdown-body h1,
    .markdown-body h2,
    .markdown-body h3 {
      line-height: 1.35;
      scroll-margin-top: 1rem;
    }

    .markdown-body h1 { margin-top: 0.25rem; }
    .markdown-body p,
    .markdown-body ul,
    .markdown-body ol,
    .markdown-body blockquote,
    .markdown-body table,
    .markdown-body pre {
      margin-top: 1rem;
      margin-bottom: 1rem;
    }

    .markdown-body pre {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      overflow-x: auto;
    }

    .markdown-body code {
      font-size: 0.9em;
      border-radius: 6px;
      padding: 0.15em 0.35em;
    }

    .markdown-body table {
      display: block;
      width: 100%;
      overflow-x: auto;
      border-collapse: collapse;
    }

    .markdown-body blockquote {
      border-left: 4px solid var(--border);
      color: var(--muted);
      background: #f8fafc;
      padding: 0.75rem 1rem;
      border-radius: 0 8px 8px 0;
    }

    @media (max-width: 768px) {
      .container { padding: 1rem 0.75rem 2rem; }
      .markdown-body {
        border-radius: 10px;
        padding: 1rem;
        font-size: 15px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="topnav"><a href="index.html">Back to top</a></div>
    <article id="content" class="markdown-body"><%= html_content %></article>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/languages/crystal.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
  <script>
    mermaid.initialize({ startOnLoad: false, securityLevel: "loose" });

    function renderMermaidBlocks(container) {
      var mermaidCodeBlocks = container.querySelectorAll("pre code.language-mermaid");
      mermaidCodeBlocks.forEach(function (codeEl, idx) {
        var pre = codeEl.closest("pre");
        if (!pre) return;

        var wrapper = document.createElement("div");
        wrapper.className = "mermaid";
        wrapper.id = "mermaid-" + idx;
        wrapper.textContent = codeEl.textContent;
        pre.replaceWith(wrapper);
      });

      if (container.querySelector(".mermaid")) {
        mermaid.run({ querySelector: ".mermaid" });
      }
    }

    function highlightCodeBlocks(container) {
      var codeBlocks = container.querySelectorAll("pre code");
      codeBlocks.forEach(function (codeEl) {
        if (codeEl.classList.contains("language-mermaid")) return;
        hljs.highlightElement(codeEl);
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      var content = document.getElementById("content");
      highlightCodeBlocks(content);
      renderMermaidBlocks(content);
    });
  </script>
</body>
</html>
